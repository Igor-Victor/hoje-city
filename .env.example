# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/hoje_city"

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Minimum 256 bits of entropy (64 hex chars). Generate: openssl rand -hex 32
JWT_SECRET="replace_with_64_char_hex_string_minimum_256_bits_entropy_here_xx"
# Access token expiry (e.g. "1h", "30m")
JWT_EXPIRES_IN="1h"
# Refresh token expiry (e.g. "7d")
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Email (Nodemailer / Resend / SendGrid) ───────────────────────────────────
SMTP_HOST="smtp.resend.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="resend"
SMTP_PASS="your_smtp_password_here"
EMAIL_FROM="Hoje.city <ola@hoje.city>"

# ─── Security ────────────────────────────────────────────────────────────────
# Set to "true" in production to enforce Secure cookies + HTTPS redirect
COOKIE_SECURE="false"
